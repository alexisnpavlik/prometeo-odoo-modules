<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_pricelist_enforce" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pricelist.enforce</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_module_pos_discount']/ancestor::setting[1]" position="after">
                <setting string="Forzar precio de lista al cobrar"
                         help="Corrige el bug del POS que a veces deja las líneas a precio público en vez del fijo de la lista.">
                    <field name="pos_pricelist_enforce"/>
                    <div class="content-group mt16" invisible="not pos_pricelist_enforce">
                        <div class="row">
                            <field name="pos_pricelist_enforce_warn" class="col-lg-1 mt4"/>
                            <label for="pos_pricelist_enforce_warn" class="o_light_label"/>
                        </div>
                    </div>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
