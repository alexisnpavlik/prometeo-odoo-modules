<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Renombra el botón "Recibo/Factura" (js_invoice) a "Imprimir" -->
    <t t-inherit="point_of_sale.PaymentScreenButtons" t-inherit-mode="extension">
        <xpath expr="//button[contains(@class,'js_invoice')]/span" position="replace">
            <span><i class="fa fa-file-text-o me-2"/>Imprimir</span>
        </xpath>
    </t>

</templates>
