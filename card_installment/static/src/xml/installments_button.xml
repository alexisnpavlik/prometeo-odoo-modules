<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Extendemos la plantilla PaymentScreenButtons -->
    <t t-inherit="point_of_sale.PaymentScreenButtons" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'payment-buttons')]" position="inside">
            
            <button class="button btn btn-light btn-lg lh-lg" id="button_installments"
                    t-att-disabled="isInstallmentsButtonDisabled"
                    t-on-click="() => this.onClickInstallments()">
                <i class="fa fa-credit-card me-2" />
                Cuotas
            </button>

            <!-- Campo de Referencia de Pago -->
            <div class="payment-reference-container mt-2">
                <div class="input-group">
                    <span class="input-group-text">
                        <i class="fa fa-tag" />
                    </span>
                    <input type="text" 
                           class="form-control form-control-lg text-start" 
                           placeholder="Referencia de pago (opcional)" 
                           t-on-input="onPaymentReferenceInput" 
                           t-att-value="currentOrderPaymentReference"/>
                </div>
            </div>

            <!-- Indicador Visual Flotante de Cuotas Seleccionadas -->
            <t t-if="!isInstallmentsButtonDisabled">
                <div class="installment-selected-badge position-absolute bottom-0 end-0 m-3 p-3 rounded-3 shadow-lg d-flex align-items-center bg-white border border-2 t-transition-all" 
                     t-att-class="selectedInstallmentQty ? 'border-success' : 'border-warning'"
                     style="z-index: 1000; min-width: 240px; pointer-events: none;">
                    <div class="me-3 rounded-circle d-flex align-items-center justify-content-center" 
                         t-att-class="selectedInstallmentQty ? 'bg-success text-white' : 'bg-warning text-dark'"
                         style="width: 40px; height: 40px; font-size: 1.2rem;">
                        <i t-att-class="selectedInstallmentQty ? 'fa fa-check-circle' : 'fa fa-exclamation-triangle'"/>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold" style="font-size: 0.75rem;">PLAN DE CUOTAS</div>
                        <div class="fw-bold" t-att-class="selectedInstallmentQty ? 'text-success' : 'text-warning'" style="font-size: 1rem;">
                            <t t-if="selectedInstallmentQty">
                                <t t-esc="selectedInstallmentQty"/> cuotas
                            </t>
                            <t t-else="">
                                Sin seleccionar
                            </t>
                        </div>
                    </div>
                </div>
            </t>

        </xpath>
    </t>

</templates>