<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Heredar la vista de formulario de product.template del módulo stock -->
    <record id="view_template_property_form_inherit_pos_stock_readonly" model="ir.ui.view">
        <field name="name">product.template.stock.form.inherit.pos.stock.readonly</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_open_quants']" position="attributes">
                <attribute name="groups">stock.group_stock_user,pos_user_stock_readonly.group_pos_user_stock_readonly</attribute>
            </xpath>
            <xpath expr="//button[@name='action_product_forecast_report']" position="attributes">
                <attribute name="groups">stock.group_stock_user,pos_user_stock_readonly.group_pos_user_stock_readonly</attribute>
            </xpath>
        </field>
    </record>

    <!-- Heredar la vista de formulario de product.product (variante) del módulo stock -->
    <record id="product_form_view_procurement_button_inherit_pos_stock_readonly" model="ir.ui.view">
        <field name="name">product.product.stock.form.inherit.pos.stock.readonly</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.product_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_open_quants']" position="attributes">
                <attribute name="groups">stock.group_stock_user,pos_user_stock_readonly.group_pos_user_stock_readonly</attribute>
            </xpath>
            <xpath expr="//button[@name='action_product_forecast_report']" position="attributes">
                <attribute name="groups">stock.group_stock_user,pos_user_stock_readonly.group_pos_user_stock_readonly</attribute>
            </xpath>
        </field>
    </record>

</odoo>
