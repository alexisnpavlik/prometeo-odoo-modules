<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Validation Method Selection Popup -->
    <t t-name="pos_special_approval_omax.ValidationMethodPopup" owl="1">
        <Dialog size="'md'" title="props.title || 'Select Validation Method'">
            <div class="validation-method-popup">
                <div class="validation-methods-container">
                    <h4 class="text-center mb-4">Choose validation method:</h4>
                    <div class="row">
                        <t t-foreach="validationMethods" t-as="method" t-key="method.key">
                            <div class="col-md-4 mb-3">
                                <button class="btn btn-outline-primary btn-lg w-100 method-btn" 
                                        t-on-click="selectMethod.bind(this, method)">
                                    <i t-attf-class="fa fa-2x {{method.icon}} mb-2"></i>
                                    <div t-esc="method.label"></div>
                                </button>
                            </div>
                        </t>
                    </div>
                </div>
                <t t-set-slot="footer">
                    <div class="validation-popup-footer mt-4">
                        <button class="btn btn-secondary" t-on-click="cancel">Cancel</button>
                    </div>
                </t>
            </div>
        </Dialog>
    </t>

    <!-- Barcode Validation Popup -->
    <t t-name="pos_special_approval_omax.BarcodeValidationPopup" owl="1">
        <Dialog size="'md'" title="props.title || 'Barcode Validation'">
            <div class="barcode-validation-popup">
                <div class="validation-content mb-2">
                    <div class="text-center mb-4">
                        <i class="fa fa-barcode fa-3x text-primary mb-3"></i>
                        <h4>Scan or Enter Barcode</h4>
                        <p class="text-muted">Please scan your manager barcode</p>
                    </div>
                    
                    <div class="input-group mb-3">
                        <input type="text" 
                               class="form-control form-control-lg text-center" 
                               placeholder="Scan or enter barcode here..."
                               t-model="state.barcode"
                               t-on-input="onBarcodeInput"
                               t-ref="barcodeInput"
                               autocomplete="off" />
                    </div>
                    <div class="text-center mb-3">
                        <button class="btn btn-outline-primary me-2" 
                            decoration-success="state.isScanning"
                            t-on-click="onScanStart"
                            t-if="!state.isScanning">
                            <i class="fa fa-camera me-2"></i>Start Scanning
                        </button>
                        <button class="btn btn-outline-danger" 
                            t-on-click="onScanStop"
                            t-if="state.isScanning">
                            <i class="fa fa-stop me-2"></i>Stop Scanning
                        </button>
                    </div>
                    <ValidationBarcodeScanner t-if="state.isScanning" onResult.bind="onCameraScanResult"/>
                </div>
                <t t-set-slot="footer">
                    <div class="validation-popup-footer">
                        <button class="btn btn-secondary me-2" t-on-click="cancel">Cancel</button>
                        <button class="btn btn-primary" 
                                t-on-click="confirm"
                                t-att-disabled="!state.barcode.trim()">
                            Validate
                        </button>
                    </div>
                </t>
            </div>
        </Dialog>
    </t>

    <t t-name="pos_special_approval_omax.PasswordValidationPopup" owl="1">
        <Dialog size="'lg'" title="props.title || 'Password Validation'">
            <div class="password-validation-popup">
                <div class="validation-content">
                    <div class="text-center mb-4">
                        <i class="fa fa-lock fa-3x text-primary mb-3"></i>
                        <h4>Enter Manager Password</h4>
                        <p class="text-muted">Please enter your manager password</p>
                    </div>
                    
                    <div class="input-group mb-3">
                        <input t-attf-type="{{state.showPassword ? 'text' : 'password'}}" 
                            class="form-control form-control-lg text-center" 
                            placeholder="Enter password..."
                            t-model="state.password"
                            t-on-input="onPasswordInput"
                            t-ref="passwordInput"
                            autocomplete="new-password" />
                        <button class="btn btn-outline-secondary" 
                                type="button" 
                                t-on-click="togglePasswordVisibility">
                            <i t-attf-class="fa {{state.showPassword ? 'fa-eye-slash' : 'fa-eye'}}"></i>
                        </button>
                    </div>

                    <div class="virtual-keyboard mt-4" t-if="state.showVirtualKeyboard">
                        
                        <div class="keyboard-container p-3">
                            <!-- Main Keyboard Rows -->
                            <t t-foreach="virtualKeyboardKeys.rows" t-as="row" t-key="row_index">
                                <div class="keyboard-row d-flex justify-content-center mb-2">
                                    <t t-foreach="row" t-as="keyObj" t-key="keyObj.key">
                                        <button t-attf-class="btn keyboard-key me-1 {{keyObj.class || 'btn-outline-primary'}}"
                                                t-on-click="onVirtualKeyPress.bind(this, keyObj.key, keyObj.special)"
                                                t-attf-data-key="{{keyObj.key}}">
                                            <span t-esc="keyObj.display"></span>
                                        </button>
                                    </t>
                                </div>
                            </t>
                            
                            <!-- Bottom Row with Special Keys -->
                            <div class="keyboard-bottom-row d-flex justify-content-center flex-wrap mt-3">
                                <t t-foreach="virtualKeyboardKeys.bottomRow" t-as="keyObj" t-key="keyObj.key">
                                    <button t-attf-class="btn keyboard-key me-1 mb-1 {{keyObj.class || 'btn-outline-primary'}}"
                                            t-on-click="onVirtualKeyPress.bind(this, keyObj.key, keyObj.special)"
                                            t-attf-data-key="{{keyObj.key}}">
                                        <span t-esc="keyObj.display"></span>
                                    </button>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                
                <t t-set-slot="footer">
                    <div class="validation-popup-footer">
                        <button class="btn btn-secondary me-2" t-on-click="cancel">Cancel</button>
                        <button class="btn btn-primary" 
                                t-on-click="confirm"
                                t-att-disabled="!state.password.trim()">
                            Validate
                        </button>
                    </div>
                </t>
            </div>
        </Dialog>
    </t>

    <!-- PIN Validation Popup -->
    <t t-name="pos_special_approval_omax.PinValidationPopup" owl="1">
        <Dialog size="'md'" title="props.title || 'PIN Validation'">
            <div class="pin-validation-popup">
                <div class="validation-content">
                    <div class="text-center mb-4">
                        <i class="fa fa-key fa-3x text-primary mb-3"></i>
                        <h4>Enter Manager PIN</h4>
                        <p class="text-muted">Please enter your manager PIN</p>
                    </div>
                    
                    <div class="input-group mb-3">
                        <input t-attf-type="{{state.showPin ? 'text' : 'password'}}" 
                               class="form-control form-control-lg text-center" 
                               placeholder="Enter PIN..."
                               t-model="state.pin"
                               t-on-input="onPinInput"
                               t-ref="pinInput"
                               maxlength="10"
                               autocomplete="new-password" />
                        <button class="btn btn-outline-secondary" 
                                type="button" 
                                t-on-click="togglePinVisibility">
                            <i t-attf-class="fa {{state.showPin ? 'fa-eye-slash' : 'fa-eye'}}"></i>
                        </button>
                    </div>

                    <!-- Number Pad -->
                    <t t-foreach="numberPadKeys" t-as="row" t-key="row_index">
                        <div class="numberpad-row mb-2 d-flex justify-content-center">
                            <t t-foreach="row" t-as="keyObj" t-key="keyObj.key">
                                <button t-attf-class="btn numberpad-key me-2 mb-1 keyboard-key {{keyObj.class}}"
                                        t-on-click="onNumberPadPress.bind(this, keyObj.key)"
                                        t-attf-data-key="{{keyObj.key}}">
                                    <span t-esc="keyObj.display"></span>
                                </button>
                            </t>
                        </div>
                    </t>
                </div>
                
                <t t-set-slot="footer">
                    <div class="validation-popup-footer">
                        <button class="btn btn-secondary me-2" t-on-click="cancel">Cancel</button>
                        <button class="btn btn-primary" 
                                t-on-click="confirm"
                                t-att-disabled="!state.pin.trim()">
                            Validate
                        </button>
                    </div>
                </t>
            </div>
        </Dialog>
    </t>

    <!-- Wrong Validation Popup -->
    <t t-name="pos_special_approval_omax.WrongValidationPopup" owl="1">
        <Dialog size="'md'" title="props.title || 'Validation Failed'">
            <div class="wrong-validation-popup">
                <div class="validation-content text-center">
                    <div class="mb-4">
                        <i class="fa fa-times-circle fa-4x text-danger mb-3"></i>
                        <h4 class="text-danger">Validation Failed</h4>
                        <p class="text-muted" t-esc="displayMessage"></p>
                    </div>
                    
                    <div class="countdown-container">
                        <p class="mb-3">This dialog will close automatically in:</p>
                        <div class="countdown-circle">
                            <span class="countdown-number" t-esc="state.countdown"></span>
                        </div>
                    </div>
                </div>
                
                <t t-set-slot="footer">
                    <div class="validation-popup-footer">
                        <button class="btn btn-primary w-100" t-on-click="close">
                            OK
                        </button>
                    </div>
                </t>
            </div>
        </Dialog>
    </t>

</templates>